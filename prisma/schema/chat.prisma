// Chat related models

enum MessageType {
    TEXT
    IMAGE
    FILE
}

model Room {
    id         String   @id @default(cuid())
    userId     String
    workshopId String
    bookingId  String?
    name       String?
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    messages Message[]

    @@map("rooms")
}

model Message {
    id        String      @id @default(cuid())
    roomId    String
    senderId  String
    content   String?
    type      MessageType @default(TEXT)
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt

    room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

    @@map("messages")
}

model Notification {
    id                 String   @id @default(cuid())
    receiverUserId     String?
    receiverWorkshopId String?
    title              String?
    body               String?
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@map("notifications")
}

model ChatNotification {
    id            String   @id @default(cuid())
    chatRoomId    String
    messageId     String?
    triggeredById String
    title         String?
    body          String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@map("chat_notifications")
}
